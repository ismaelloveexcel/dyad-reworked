# Generated App — Environment Variables
# Copy this file to .env and fill in your values.
# Your actual .env file should NOT be committed.

# Checkout URL — required for the pricing/checkout section.
# Paste any hosted payment or checkout link here. Supported providers include:
#   - Lemon Squeezy: https://app.lemonsqueezy.com → Products → Share → Checkout URL
#   - Stripe Payment Link: https://dashboard.stripe.com → Payment Links
#   - Gumroad: https://app.gumroad.com → Products → Share
#   - Ko-fi: https://ko-fi.com → Commissions / Shop
#   - Manual payment page: any URL you control
VITE_CHECKOUT_URL=
